{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "ignoreDeprecations": "5.0",
    "baseUrl": "/app",
    "paths": {
      "@lib/*": ["libs/*/src"]
    }
  },
  "include": ["services/futures/src/**/*"],
  "exclude": ["node_modules"]
}
